# Ignore everything by default
*

# Allow the dags directory
!dags/
# Allow all files and subdirectories inside dags/
!dags/**

# Allow .gitignore so these rules are versioned
!.gitignore

# Still ignore Python artifacts inside dags
dags/**/__pycache__/
dags/**/*.py[cod]
dags/**/*$py.class

# Track CI workflow files
!.github/
!.github/workflows/
!.github/workflows/**
